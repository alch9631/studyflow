# Local dev: SQLite, zero setup. Just copy this file to .env (npm run setup does it).
DATABASE_URL="file:./dev.db"

# --- Optional ---

# Claude API — turns on AI syllabus import + handbook topic extraction.
# Without it the app still runs; those features show an "add your key" notice.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Production only (see PRODUCTION.md) ---
# For production, switch prisma/schema.prisma provider to "postgresql" and set:
# DATABASE_URL="postgresql://user:password@host:5432/postgres"
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
