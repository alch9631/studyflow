# Local dev: SQLite, zero setup. Just copy this file to .env (npm run setup does
# it). DATABASE_URL is the only required var; the test runner / CI even default
# it to "file:./dev.db" when it's unset.
DATABASE_URL="file:./dev.db"

# --- Authentication (Auth.js / NextAuth v5, Google sign-in) ---
# AUTH_SECRET   signing key for sessions/JWT. Generate with: npx auth secret
#               (or: openssl rand -base64 33). Required in production.
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET  Google OAuth Web client credentials. See
#               DEPLOY.md for the Google Cloud setup + redirect URIs. Leave blank
#               and Google sign-in is disabled.
# ALLOW_DEV_USER  In any NON-production environment (NODE_ENV !== "production")
#               the app already falls back to the seeded local dev user, so plain
#               `npm run dev` / tests need NO flag. Set this to 1 ONLY to force
#               that fallback under NODE_ENV=production (e.g. the Pi running with
#               no Google creds). Unset/0 in real production to enforce sign-in.
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
ALLOW_DEV_USER=""

# --- Optional ---

# AI features (syllabus/material import, handbook topics, progress parsing).
# Set EITHER key — OpenAI is used if both are present. App runs fine without one.
#   OpenAI:    https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Web push (study-reminder notifications). All three must be set to enable
# sending — leave them blank and the feature is a safe no-op (no notifications,
# nothing throws). Generate a keypair once with: npx web-push generate-vapid-keys
#   VAPID_PUBLIC_KEY   also expose to the browser as NEXT_PUBLIC_VAPID_PUBLIC_KEY
#   VAPID_PRIVATE_KEY  server-only secret — never commit a real value
#   VAPID_SUBJECT      a mailto: or https: contact URL (defaults to a mailto:)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Daily study-reminder trigger (POST /api/reminders/run). A scheduler calls the
# endpoint once a day with `Authorization: Bearer $CRON_SECRET`; it then pushes
# each subscribed user a summary of today's plan. Leave blank and the endpoint is
# a safe no-op (returns { disabled: true }, sends nothing). Generate any long
# random string, e.g.: openssl rand -hex 32
CRON_SECRET=""

# --- Production only (see PRODUCTION.md) ---
# For production, switch prisma/schema.prisma provider to "postgresql" and set:
# DATABASE_URL="postgresql://user:password@host:5432/postgres"
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
