{
  "name": "studyflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/ensure-env.mjs && prisma db push && tsx prisma/seed.ts && tsx prisma/seedCatalog.ts",
    "dev": "next dev",
    "fresh": "pkill -f 'next dev' 2>/dev/null; pkill -f next-server 2>/dev/null; sleep 1; prisma db push && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ci": "node scripts/prisma-bootstrap.mjs && npm run lint && tsc --noEmit && npm test && npm run build",
    "pretest": "node scripts/prisma-bootstrap.mjs",
    "test": "node scripts/test-all.mjs",
    "test:engine": "tsx src/lib/planner.test.ts",
    "test:service": "tsx src/lib/planService.test.ts",
    "test:spread": "tsx src/lib/planSpread.test.ts",
    "test:dates": "tsx src/lib/dates.test.ts",
    "test:calendar-time": "tsx src/lib/calendarTime.test.ts",
    "test:calendar-layout": "tsx src/lib/calendarLayout.test.ts",
    "test:ics": "tsx src/lib/ics.test.ts",
    "test:syllabus": "tsx src/lib/syllabus.test.ts",
    "test:filecategory": "tsx src/lib/fileCategory.test.ts",
    "test:stats": "tsx src/lib/stats.test.ts",
    "test:streak-ui": "tsx src/components/lib/streak.test.ts",
    "test:overlay-open": "tsx src/components/lib/overlayOpen.test.ts",
    "test:action-queue": "tsx src/components/lib/actionQueue.test.ts",
    "test:cache": "tsx src/lib/statsCache.test.ts",
    "test:studytime": "tsx src/lib/studyTime.test.ts",
    "test:validate": "tsx src/lib/validate.test.ts",
    "test:limits": "tsx src/lib/limits.test.ts",
    "test:ratelimit": "tsx src/lib/rateLimitPolicy.test.ts",
    "test:push": "tsx src/lib/push.test.ts",
    "test:push-routes": "tsx src/lib/pushRoutes.test.ts",
    "test:reminders": "tsx src/lib/reminders.test.ts",
    "test:api-routes": "tsx src/lib/apiRoutes.test.ts",
    "test:route-errors": "tsx src/lib/routeErrors.test.ts",
    "test:apierror": "tsx src/lib/apiError.test.ts",
    "test:action-errors": "tsx src/lib/actionErrors.test.ts",
    "test:export": "tsx src/lib/export.test.ts",
    "test:today-fetch": "tsx src/lib/todayFetch.test.ts",
    "test:pagination": "tsx src/lib/pagination.test.ts",
    "test:block-service": "tsx src/lib/blockService.test.ts",
    "test:ownership": "tsx src/lib/ownership.test.ts",
    "test:recovery": "tsx src/lib/recovery.test.ts",
    "test:testdb": "tsx src/lib/testDb.test.ts",
    "test:bootstrap": "tsx src/lib/prismaBootstrap.test.ts",
    "test:timeplacer": "tsx src/lib/timePlacer.test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:catalog": "tsx prisma/seedCatalog.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
