{
  "name": "studyflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/ensure-env.mjs && prisma db push && tsx prisma/seed.ts && tsx prisma/seedCatalog.ts",
    "dev": "next dev",
    "fresh": "pkill -f 'next dev' 2>/dev/null; pkill -f next-server 2>/dev/null; sleep 1; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:engine": "tsx src/lib/planner.test.ts",
    "test:service": "tsx src/lib/planService.test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:catalog": "tsx prisma/seedCatalog.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.107.0",
    "mammoth": "^1.12.0",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
